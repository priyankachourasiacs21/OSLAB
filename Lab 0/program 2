//  Write a program in C to find the sum of the left diagonals of a matrix
#include <stdio.h>

int main(){
    int n;
    printf("For size of square matrix n x n, Enter n: ");
    scanf("%d",&n);
    int mat[n][n];
    for(int i=0;i<n;i++){
        for(int j=0;j<n;j++){
            printf("Enter element matrix[%d][%d]: ",i,j);
            scanf("%d",&mat[i][j]);
        }
    }
    int sum=0;
    for(int i=0;i<n;i++){
        for(int j=0;j<n;j++){
            if(i==j)    sum+=mat[i][j];
        }
    }
    printf("Left diogonal sum: %d\n",sum);

}
